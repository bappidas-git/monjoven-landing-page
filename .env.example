# ============================================
# Environment Variables Example
# Landing Page Boilerplate
# ============================================
# Copy this file to .env and update the values accordingly

# Application Configuration
REACT_APP_NAME="Your Business Name"
REACT_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# Project Information
REACT_APP_PROJECT_NAME="Your Business Name"
REACT_APP_DEVELOPER_NAME="Your Company Name"
REACT_APP_PROJECT_LOCATION="Your City, Your State"

# Admin Panel Credentials (change these in production!)
REACT_APP_ADMIN_USERNAME="admin"
REACT_APP_ADMIN_PASSWORD="changeme123"

# Contact Information
REACT_APP_SALES_PHONE="+91-XXXXXXXXXX"
REACT_APP_WHATSAPP_NUMBER="+91XXXXXXXXXX"
REACT_APP_SALES_EMAIL="info@yourbusiness.com"
REACT_APP_SUPPORT_EMAIL="support@yourbusiness.com"

# Office Address
REACT_APP_OFFICE_ADDRESS="Your Office Address Here"

# Social Media Links (optional)
REACT_APP_FACEBOOK_URL="https://facebook.com/yourpage"
REACT_APP_INSTAGRAM_URL="https://instagram.com/yourpage"
REACT_APP_YOUTUBE_URL="https://youtube.com/yourchannel"
REACT_APP_LINKEDIN_URL="https://linkedin.com/company/yourcompany"

# Google Maps Configuration
# Get API key from: https://console.cloud.google.com/
REACT_APP_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
REACT_APP_PROJECT_LATITUDE="0.0000"
REACT_APP_PROJECT_LONGITUDE="0.0000"

# Analytics & Tracking
# Google Tag Manager: https://tagmanager.google.com/
REACT_APP_GTM_ID="GTM-XXXXXXX"
# Google Analytics 4: https://analytics.google.com/
REACT_APP_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
# Google Ads: https://ads.google.com/
REACT_APP_GOOGLE_ADS_ID="AW-XXXXXXXXXX"
# Google Ads Conversion Tracking
REACT_APP_GOOGLE_ADS_CONVERSION_LABEL="XXXXXXXXXX"
REACT_APP_GOOGLE_ADS_CONVERSION_VALUE="0"
# Enable enhanced conversions (sends hashed PII to Google for better attribution)
REACT_APP_GOOGLE_ADS_ENHANCED_CONVERSIONS=false
# Meta (Facebook) Pixel: https://business.facebook.com/
REACT_APP_META_PIXEL_ID="XXXXXXXXXXXXXXX"
REACT_APP_FB_PIXEL_ID="XXXXXXXXXXXXXXX"
# Meta Conversions API (CAPI) endpoint for server-side tracking
REACT_APP_META_CAPI_ENDPOINT="/api/meta-capi.php"
# Meta Test Event Code (from Events Manager > Test Events, remove in production)
REACT_APP_META_TEST_EVENT_CODE=""
# Enable/disable consent mode (set true when using a cookie consent banner)
REACT_APP_ENABLE_CONSENT_MODE=false

# API Endpoints (if needed for form submissions)
REACT_APP_API_BASE_URL="https://api.yourbackend.com"
REACT_APP_LEAD_SUBMISSION_ENDPOINT="/api/leads"

# Hero Video (set URL to enable hero background video)
REACT_APP_HERO_VIDEO_URL=""

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_CHAT_WIDGET=false
REACT_APP_ENABLE_EMI_CALCULATOR=true
REACT_APP_ENABLE_VIRTUAL_TOUR=false

# Performance Settings
REACT_APP_IMAGE_CDN_URL="https://cdn.yourcdnprovider.com"
REACT_APP_LAZY_LOAD_OFFSET=100

# ============================================
# Lead Management (Admin Panel) — REQUIRED
# ============================================
# The Admin Panel stores leads on your server so every admin sees every
# lead, from every device. Set these two in tandem with config.php.
#
# URL of the leads API endpoint. Leave as default unless leads.php
# lives on a different domain (then use the full URL).
REACT_APP_LEADS_API_URL="/api/leads.php"
# Shared secret used to list/update/delete leads from the admin panel.
# MUST EXACTLY match ADMIN_API_KEY defined in public/api/config.php.
# Generate a long random string (e.g., from random.org/strings/).
REACT_APP_LEADS_ADMIN_KEY=""

# ============================================
# Admin Panel Pabbly Webhook — OPTIONAL
# ============================================
# Only set this if you want admin actions (status changes, notes,
# deletions) to ALSO be mirrored to a SECOND Pabbly workflow (e.g., to
# update a separate Google Sheet or send a Slack ping).
# Lead Management works perfectly without this — leave blank by default.
REACT_APP_ADMIN_PABBLY_WEBHOOK_URL=""

# Build Information (auto-populated during build)
REACT_APP_BUILD_DATE=""
REACT_APP_BUILD_NUMBER=""
